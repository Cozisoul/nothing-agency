#### **Step 2: Create the Sketch Logic (`src/scripts/sketches/grid.ts`)**

We will write the p5.js logic in "Instance Mode" so it plays nicely with Astro and doesn't pollute the global scope.

1.  Create a folder: `src/scripts/sketches`
2.  Create a file: `src/scripts/sketches/grid.ts`

**Paste this code:**

```typescript
import type p5 from 'p5';

export const gridSketch = (p: p5) => {
  // CONFIGURATION
  const gap = 40; // Space between points
  const pointSize = 2;
  const influenceRadius = 150; // How far the mouse affects points
  const force = 0.5; // How strongly they move away

  let points: { x: number; y: number; originalX: number; originalY: number }[] = [];

  p.setup = () => {
    // Create a canvas that fills the window
    p.createCanvas(window.innerWidth, window.innerHeight);
    p.noStroke();
    p.fill(60); // Subtle Grey (#3C3C3C) - Visible but quiet on black
    
    // Generate the Grid Data
    createGrid();
  };

  p.draw = () => {
    p.clear(); // Transparent background

    // Loop through all points
    for (let i = 0; i < points.length; i++) {
      const pt = points[i];
      
      // Calculate distance to mouse
      const d = p.dist(p.mouseX, p.mouseY, pt.originalX, pt.originalY);

      // THE PHYSICS: Displacement
      if (d < influenceRadius) {
        const angle = p.atan2(pt.originalY - p.mouseY, pt.originalX - p.mouseX);
        // Move point away from mouse based on proximity
        const offset = p.map(d, 0, influenceRadius, gap * force, 0);
        pt.x = pt.originalX + p.cos(angle) * offset;
        pt.y = pt.originalY + p.sin(angle) * offset;
      } else {
        // Return to original position (Elasticity)
        // Simple lerp for smooth return
        pt.x = p.lerp(pt.x, pt.originalX, 0.1);
        pt.y = p.lerp(pt.y, pt.originalY, 0.1);
      }

      // Draw the point
      p.circle(pt.x, pt.y, pointSize);
    }
  };

  p.windowResized = () => {
    p.resizeCanvas(window.innerWidth, window.innerHeight);
    createGrid();
  };

  function createGrid() {
    points = [];
    for (let x = gap / 2; x < window.innerWidth; x += gap) {
      for (let y = gap / 2; y < window.innerHeight; y += gap) {
        points.push({
          x: x,
          y: y,
          originalX: x,
          originalY: y
        });
      }
    }
  }
};
```

