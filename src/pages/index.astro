---
import MainLayout from "../layouts/MainLayout.astro";
import EntryGate from "../components/EntryGate.astro";
import Header from "../components/Header.astro";
import ProjectCard from "../components/ProjectCard.astro";
import WorkFeed from "../components/work/WorkFeed.tsx";
import Office from "../components/Office.astro";
import Footer from "../components/Footer.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
const sortedProjects = projects.sort((a, b) => a.data.order - b.data.order);
---

<MainLayout title="*nothing...">
  <EntryGate />

  <Header />

  <!-- The Main Container: Enforces the Right-Side Axis -->
  <main class="px-6 md:px-12 pt-24 pb-12 w-full max-w-[1800px] mx-auto">
    <!-- MANIFESTO FIX -->
    <!-- w-full md:w-2/3 lg:w-1/2 ml-auto: This forces it to occupy ONLY the right half -->
    <section
      id="manifesto"
      class="min-h-[50vh] flex flex-col justify-center items-end text-right border-b border-muted/20 mb-16"
    >
      <div class="w-full md:w-3/4 lg:w-1/2 ml-auto">
        <h2
          class="kinetic-text origin-right will-change-transform font-sys text-fluid-h2 leading-[1.1] mb-8 font-medium text-fg"
        >
          We are a transdisciplinary office. We merge systematic rigor with
          poetic inquiry.
        </h2>
        <p class="font-mono text-xs text-accent tracking-widest uppercase">
          * SCROLL TO EXPLORE
        </p>
      </div>
    </section>

    <!-- WORK SECTION FIX -->
    <section id="work" class="min-h-screen mb-16">
      <!-- We load the WorkFeed. 
           client:load tells Astro to hydrate this React component immediately 
           so the interactive toggle works. -->
      <WorkFeed projects={sortedProjects} client:load />
    </section>

    <!-- OFFICE SECTION & FOOTER Integrated for Flow -->
    <!-- Office is already a component, but we will wrap it to ensure it sits in the grid if it doesn't already -->
    <!-- Actually, let's just use the Office component but ensure IT enforces the grid internally or we wrap it here. 
         The user asked to tighten spacing in Office. Let's rely on Office component for internal structure 
         but we might need to adjust it to match the w-1/2 grid if it isn't strict enough. 
         The Office component currently has w-full md:w-2/3 lg:w-1/2 ml-auto. That matches the strictness.
    -->
    <Office />
  </main>

  <div class="px-6 md:px-12 w-full max-w-[1800px] mx-auto">
    <Footer />
  </div>
</MainLayout>
