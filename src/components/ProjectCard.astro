---
// src/components/ProjectCard.astro
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { data } = project;
---

<a
  href={data.link}
  target="_blank"
  rel="noopener noreferrer"
  class="group block w-full cursor-pointer text-left"
  data-cursor="CASE STUDY"
>
  <!-- Image Container -->
  <div class="relative w-full aspect-[4/3] overflow-hidden bg-bg-light mb-4">
    <img
      src={data.image}
      alt={data.title}
      class="w-full h-full object-cover transition-transform duration-700 ease-[cubic-bezier(0.25,1,0.5,1)] group-hover:scale-105 opacity-90 group-hover:opacity-100"
    />
    <div
      class="absolute inset-0 bg-bg/10 transition-opacity duration-500 group-hover:opacity-0"
    >
    </div>
  </div>

  <!-- Meta Data Grouping -->
  <!-- Left aligned for readability in dense grid -->
  <div class="flex flex-col items-start gap-1 border-t border-muted/20 pt-3">
    <!-- Top Row: Tag & Date -->
    <div
      class="flex gap-4 font-mono text-[10px] tracking-widest uppercase text-muted"
    >
      <span class="text-accent">* {data.tag}</span>
      <span>[{data.year}]</span>
    </div>

    <!-- Title: The Anchor -->
    <h3
      class="font-sys font-bold text-2xl md:text-3xl text-fg group-hover:text-accent transition-colors duration-300 leading-none mt-1"
    >
      {data.title}
    </h3>
  </div>

  <!-- Description: Left aligned -->
  <div class="flex justify-start mt-4">
    <p class="font-sys text-muted text-xs max-w-[40ch] leading-relaxed">
      {project.body}
    </p>
  </div>
</a>
